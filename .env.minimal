VERSION=1.4.2
# CML Server (required)
DATABASE__POSTGRES_URL=postgresql+asyncpg://memory:memory@localhost/memory
AUTH__API_KEY=test-key

# Client / examples (required)
CML_API_KEY=test-key
CML_BASE_URL=http://localhost:8000
CML_ADMIN_API_KEY=test-key
# Optional but highly recommended
DATABASE__NEO4J_URL=bolt://localhost:7687
DATABASE__NEO4J_USER=neo4j
DATABASE__NEO4J_PASSWORD=password
DATABASE__NEO4J_BROWSER_URL=bolt://localhost:7687
DATABASE__REDIS_URL=redis://localhost:6379
AUTH__ADMIN_API_KEY=test-key

FEATURES__USE_LLM_ENABLED=false

LLM_INTERNAL__PROVIDER=openai_compatible
LLM_INTERNAL__MODEL=Qwen/Qwen3.5-27B
LLM_INTERNAL__BASE_URL=http://localhost:8001/v1

LLM_EVAL__PROVIDER=openai_compatible
LLM_EVAL__MODEL=Qwen/Qwen3.5-27B
LLM_EVAL__BASE_URL=http://localhost:8001/v1

# Embedding: local sentence-transformers on GPU (auto-detects CUDA)
EMBEDDING_INTERNAL__PROVIDER=local
EMBEDDING_INTERNAL__LOCAL_MODEL=nomic-ai/nomic-embed-text-v2-moe
EMBEDDING_INTERNAL__DIMENSIONS=768

# Summarizer: HuggingFace pipeline on GPU (device=-1 = auto-detect CUDA; set to 0 to force GPU 0)
SUMMARIZER_INTERNAL__PROVIDER=huggingface
SUMMARIZER_INTERNAL__MODEL=Falconsai/text_summarization
SUMMARIZER_INTERNAL__DEVICE=-1
